# Telegram Credentials
# Get API_ID and API_HASH from https://my.telegram.org
API_ID=
API_HASH=
# String session generated after first interactive login (leave blank initially)
STRING_SESSION=

# Telegram Source Channel/Group username, chat ID (e.g. -100xxx), or title
TELEGRAM_CHAT=

# Discord Credentials
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

# Discord role to mention when forwarding (leave blank to disable role mention)
MENTION_ROLE_ID=
# If true, mention the role for every message. If false, only mentions when the Telegram message contains an @everyone, @here, alert, or ping keyword.
MENTION_EVERY_MESSAGE=true

# Customization Options
# Embed Color hex code (default is Discord Blurple #5865F2)
EMBED_COLOR=#5865F2

# Forward message edits
FORWARD_EDITS=false

# Media forward configuration
DOWNLOAD_MEDIA=true
DELETE_TEMP_FILES=true
# Discord's upload limit for normal accounts is usually 25MB (or 10MB/50MB depending on boosts). 
# Default to 24MB to avoid exceeding limits.
MAX_FILE_SIZE_MB=24

# Message display format
SEND_AS_EMBED=true

# Better Embed Options
# If true, display the sender's username (if available) in the footer
SHOW_SENDER_USERNAME=true
# If true, display the source chat name as the embed author
SHOW_CHAT_NAME=true
# If true, show the Telegram message date in the embed fields
SHOW_MESSAGE_DATE=true
# If true, convert Telegram URL buttons to Discord button components
CONVERT_TELEGRAM_BUTTONS=true

# Reconnection configuration (in milliseconds)
RECONNECT_DELAY=5000
